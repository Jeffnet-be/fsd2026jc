@model IEnumerable<FullStackDevelopment_Ticketverkoop.Web.Models.ViewModels.MatchViewModel>
@{
    ViewData["Title"] = "Match Calendar";
}

<div class="container mt-4">
    <h1 class="mb-3">Champions League – Match Calendar</h1>

    @* Club filter dropdown *@
    <form method="get" class="mb-4 d-flex gap-2">
        <select name="clubId" class="form-select w-auto">
            <option value="">All clubs</option>
            @* In production, clubs would be passed via ViewBag *@
        </select>
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">No matches found.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var match in Model)
            {
                @* Partial view for each match card *@
                @await Html.PartialAsync("_MatchCard", match)
            }
        </div>
    }
</div>