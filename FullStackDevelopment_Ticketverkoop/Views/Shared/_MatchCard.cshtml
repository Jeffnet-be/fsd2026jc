@model FullStackDevelopment_Ticketverkoop.Web.Models.ViewModels.MatchViewModel

<div class="col">
    <div class="card h-100 shadow-sm">
        <div class="card-header d-flex align-items-center gap-2">
            <img src="@Model.HomeLogoUrl" alt="@Model.HomeClubName" height="32" />
            <strong>@Model.HomeClubName</strong>
            <span class="mx-2">vs</span>
            <strong>@Model.AwayClubName</strong>
        </div>
        <div class="card-body">
            <p class="mb-1">
                <i class="bi bi-calendar-event"></i>
                @Model.MatchDate.ToString("dddd dd MMMM yyyy HH:mm")
            </p>
            <p class="mb-1"><i class="bi bi-geo-alt"></i> @Model.StadiumName</p>
            <p class="mb-0"><span class="badge bg-secondary">@Model.Phase</span></p>
        </div>
        <div class="card-footer">
            <a asp-controller="Match" asp-action="Details"
               asp-route-id="@Model.Id"
               class="btn btn-sm btn-outline-primary">
                View seats &amp; buy tickets
            </a>
            <a asp-controller="Hotel" asp-action="Search"
               asp-route-city="@Model.StadiumName"
               class="btn btn-sm btn-outline-secondary">
                Find a hotel
            </a>
        </div>
    </div>
</div>