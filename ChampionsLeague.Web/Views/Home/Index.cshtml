@model IEnumerable<ChampionsLeague.Web.ViewModels.ClubCardVM>
@{
    ViewData["Title"] = "Home";
    var totalSeats = Model.Sum(c => c.TotalCapacity);
}

<!-- ── Hero ──────────────────────────────────────────────────── -->
<div style="background:linear-gradient(135deg,#001489 0%,#0a0a40 100%);
            padding:60px 0 50px">
    <div class="container text-center text-white">
        <div style="font-size:4rem;line-height:1;margin-bottom:16px">⚽</div>
        <h1 class="fw-bold mb-3"
            style="font-size:clamp(1.8rem,5vw,3rem)">
            <span style="color:#FFD700">Champions League</span><br/>
            Ticket Portal
        </h1>
        <p class="mb-4 mx-auto"
           style="max-width:480px;opacity:.85;font-size:1.05rem">
            Buy official tickets for the biggest football matches in Europe.
            Six clubs &bull; One portal &bull; Your seat guaranteed.
        </p>
        <div class="d-flex flex-wrap justify-content-center gap-3 mb-5">
            <a asp-controller="Matches" asp-action="Index"
               class="btn btn-gold btn-lg px-4 fw-bold"
               style="background:#FFD700;color:#001489;border:none;border-radius:8px">
                <i class="bi bi-calendar3 me-2"></i>View Match Calendar
            </a>
            <a asp-controller="Account" asp-action="Register"
               class="btn btn-outline-light btn-lg px-4"
               style="border-radius:8px">
                <i class="bi bi-person-plus me-2"></i>Create Account
            </a>
        </div>

        <!-- Stat pills -->
        <div class="d-flex flex-wrap justify-content-center gap-3">
            @foreach (var (label, value) in new (string,string)[] {
                ("Clubs",        Model.Count().ToString()),
                ("Matches",      "13"),
                ("Total seats",  totalSeats.ToString("N0")),
                ("Languages",    "3"),
            })
            {
                <div class="text-center px-4 py-2 rounded-3"
                     style="background:rgba(255,255,255,.12);min-width:90px">
                    <div class="fw-bold fs-5" style="color:#FFD700">@value</div>
                    <div class="small" style="color:rgba(255,255,255,.7)">@label</div>
                </div>
            }
        </div>
    </div>
</div>

<!-- ── Feature strip ──────────────────────────────────────────── -->
<div style="background:#fff;border-bottom:1px solid #e9ecef">
    <div class="container py-3">
        <div class="row text-center gy-2">
            <div class="col-md-4">
                <span class="fw-semibold"><span class="me-2">🎫</span>Official Tickets</span>
                <span class="text-muted small ms-1">— Unique voucher by email</span>
            </div>
            <div class="col-md-4">
                <span class="fw-semibold"><span class="me-2">🔒</span>Fair &amp; Secure</span>
                <span class="text-muted small ms-1">— Max 4 tickets per match</span>
            </div>
            <div class="col-md-4">
                <span class="fw-semibold"><span class="me-2">🏨</span>Hotel Search</span>
                <span class="text-muted small ms-1">— Near the stadium</span>
            </div>
        </div>
    </div>
</div>

<!-- ── Club grid ──────────────────────────────────────────────── -->
<div class="container py-5">
    <h2 class="fw-bold mb-4" style="color:#001489">
        <span style="display:inline-block;width:4px;height:28px;background:#FFD700;
                     border-radius:2px;margin-right:12px;vertical-align:middle"></span>
        Participating Clubs
    </h2>
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var club in Model)
        {
            @await Html.PartialAsync("_ClubCard", club)
        }
    </div>
</div>
