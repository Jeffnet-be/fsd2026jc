@model IEnumerable<ChampionsLeague.Web.ViewModels.ClubCardVM>
@{
    ViewData["Title"] = "Home";
    var totalSeats = Model.Sum(c => c.TotalCapacity);
}

<!-- Hero -->
<div style="background:linear-gradient(135deg,#001489 0%,#0a0a40 100%);padding:60px 0 50px">
    <div class="container text-center text-white">
        <div style="font-size:4rem;line-height:1;margin-bottom:16px">⚽</div>
        <h1 class="fw-bold mb-3" style="font-size:clamp(1.8rem,5vw,3rem)">
            <span style="color:#FFD700">Champions League</span><br/>
            @Tr.T("home_hero_title")
        </h1>
        <p class="mb-4 mx-auto" style="max-width:480px;opacity:.85;font-size:1.05rem">
            @Tr.T("home_hero_subtitle")
        </p>
        <div class="d-flex flex-wrap justify-content-center gap-3 mb-5">
            <a asp-controller="Matches" asp-action="Index"
               class="btn btn-lg fw-bold px-4 py-3"
               style="background:#FFD700;color:#001489;border:none;border-radius:8px">
                <i class="bi bi-calendar3 me-2"></i>@Tr.T("home_view_calendar")
            </a>
            <a asp-controller="Account" asp-action="Register"
               class="btn btn-outline-light btn-lg px-4 py-3" style="border-radius:8px">
                <i class="bi bi-person-plus me-2"></i>@Tr.T("home_create_account")
            </a>
        </div>
        <!-- Stats -->
        <div class="d-flex flex-wrap justify-content-center gap-3">
            @foreach (var (label, value) in new (string,string)[] {
                (Tr.T("stat_clubs"),     Model.Count().ToString()),
                (Tr.T("stat_matches"),   "13"),
                (Tr.T("stat_seats"),     totalSeats.ToString("N0")),
                (Tr.T("stat_languages"), "3"),
            })
            {
                <div class="text-center px-4 py-2 rounded-3"
                     style="background:rgba(255,255,255,.12);min-width:90px">
                    <div class="fw-bold fs-5" style="color:#FFD700">@value</div>
                    <div class="small" style="color:rgba(255,255,255,.7)">@label</div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Feature strip -->
<div style="background:#fff;border-bottom:1px solid #e9ecef">
    <div class="container py-3">
        <div class="row text-center gy-2">
            <div class="col-md-4">
                <span class="fw-semibold">🎫 @Tr.T("home_feat_tickets")</span>
                <span class="text-muted small ms-1">— @Tr.T("home_feat_tickets_sub")</span>
            </div>
            <div class="col-md-4">
                <span class="fw-semibold">🔒 @Tr.T("home_feat_fair")</span>
                <span class="text-muted small ms-1">— @Tr.T("home_feat_fair_sub")</span>
            </div>
            <div class="col-md-4">
                <span class="fw-semibold">🏨 @Tr.T("home_feat_hotel")</span>
                <span class="text-muted small ms-1">— @Tr.T("home_feat_hotel_sub")</span>
            </div>
        </div>
    </div>
</div>

<!-- Club grid -->
<div class="container py-5">
    <h2 class="fw-bold mb-4" style="color:#001489">
        <span style="display:inline-block;width:4px;height:28px;background:#FFD700;
                     border-radius:2px;margin-right:12px;vertical-align:middle"></span>
        @Tr.T("home_clubs_title")
    </h2>
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var club in Model)
        {
            @await Html.PartialAsync("_ClubCard", club)
        }
    </div>
</div>
