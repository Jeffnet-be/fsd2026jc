@model IEnumerable<ChampionsLeague.Web.ViewModels.ClubCardVM>
@{
    ViewData["Title"] = "Home";
}

<!-- ── Hero ────────────────────────────────────────────────────────── -->
<div class="position-relative overflow-hidden text-white text-center py-5"
     style="background: linear-gradient(135deg,#001489 0%,#0d0d2b 60%,#1a0a3d 100%);
            min-height:340px;">
    <!-- subtle pattern overlay -->
    <div class="position-absolute top-0 start-0 w-100 h-100"
         style="background:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22><circle cx=%2230%22 cy=%2230%22 r=%221.5%22 fill=%22rgba(255,255,255,.07)%22/></svg>') repeat;"></div>

    <div class="container position-relative py-4">
        <div class="mb-3" style="font-size:3.5rem">⚽</div>
        <h1 class="display-4 fw-bold mb-2">
            <span style="color:#FFD700">Champions League</span> Ticket Portal
        </h1>
        <p class="lead text-white-75 mb-4" style="max-width:560px;margin:0 auto">
            Buy official tickets for the biggest football matches in Europe.
            Six clubs &bull; One portal &bull; Your seat guaranteed.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Matches" asp-action="Index"
               class="btn btn-lg fw-bold px-5 py-3"
               style="background:#FFD700;color:#001489;border:none">
                <i class="bi bi-calendar3 me-2"></i>View Match Calendar
            </a>
            <a asp-controller="Account" asp-action="Register"
               class="btn btn-lg btn-outline-light px-4 py-3">
                <i class="bi bi-person-plus me-2"></i>Create Account
            </a>
        </div>

        <!-- stats row -->
        <div class="row justify-content-center mt-5 g-4">
            @{
                var totalSeats = Model.Sum(c => c.TotalCapacity);
                var clubCount  = Model.Count();
            }
            <div class="col-auto">
                <div class="px-4 py-2 rounded-3" style="background:rgba(255,255,255,.1)">
                    <div class="fw-bold fs-4" style="color:#FFD700">@clubCount</div>
                    <div class="small text-white-50">Clubs</div>
                </div>
            </div>
            <div class="col-auto">
                <div class="px-4 py-2 rounded-3" style="background:rgba(255,255,255,.1)">
                    <div class="fw-bold fs-4" style="color:#FFD700">13</div>
                    <div class="small text-white-50">Matches</div>
                </div>
            </div>
            <div class="col-auto">
                <div class="px-4 py-2 rounded-3" style="background:rgba(255,255,255,.1)">
                    <div class="fw-bold fs-4" style="color:#FFD700">@totalSeats.ToString("N0")</div>
                    <div class="small text-white-50">Total seats</div>
                </div>
            </div>
            <div class="col-auto">
                <div class="px-4 py-2 rounded-3" style="background:rgba(255,255,255,.1)">
                    <div class="fw-bold fs-4" style="color:#FFD700">3</div>
                    <div class="small text-white-50">Languages</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Feature strip ────────────────────────────────────────────────── -->
<div style="background:#f8f9ff" class="border-bottom">
    <div class="container py-3">
        <div class="row text-center g-3">
            <div class="col-md-4">
                <span class="me-2">🎫</span>
                <strong>Official Tickets</strong>
                <span class="text-muted small ms-1">— Unique voucher by email</span>
            </div>
            <div class="col-md-4">
                <span class="me-2">🔒</span>
                <strong>Fair & Secure</strong>
                <span class="text-muted small ms-1">— Max 4 tickets per match</span>
            </div>
            <div class="col-md-4">
                <span class="me-2">🏨</span>
                <strong>Hotel Search</strong>
                <span class="text-muted small ms-1">— Find hotels near the stadium</span>
            </div>
        </div>
    </div>
</div>

<!-- ── Club grid ────────────────────────────────────────────────────── -->
<div class="container py-5">
    <div class="d-flex align-items-center mb-4">
        <div class="me-3" style="width:4px;height:32px;background:#FFD700;border-radius:2px"></div>
        <h2 class="fw-bold mb-0" style="color:#001489">Participating Clubs</h2>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var club in Model)
        {
            @await Html.PartialAsync("_ClubCard", club)
        }
    </div>
</div>
