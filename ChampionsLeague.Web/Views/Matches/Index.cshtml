@model ChampionsLeague.Web.ViewModels.MatchListVM
@{
    ViewData["Title"] = Tr.T("match_calendar_title");
}

<div style="background:linear-gradient(135deg,#001489,#0d0d2b)" class="text-white py-4 mb-4">
    <div class="container">
        <h1 class="fw-bold mb-1">
            <i class="bi bi-calendar3 me-2" style="color:#FFD700"></i>@Tr.T("match_calendar_title")
        </h1>
        <p class="text-white-50 mb-0">@Tr.T("match_calendar_sub")</p>
    </div>
</div>

<div class="container pb-5">
    @if (Model.FilterClub != null)
    {
        <div class="alert alert-info d-flex align-items-center gap-2 mb-4">
            <i class="bi bi-funnel-fill"></i>
            @Model.FilterClub
            <a asp-action="Index" class="ms-2 btn btn-sm btn-outline-secondary">✕</a>
        </div>
    }

    <div class="card border-0 shadow-sm" style="border-radius:16px;overflow:hidden">
        <div class="card-body p-0">
            <table id="matchTable" class="table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Phase</th>
                        <th>Home</th>
                        <th>Away</th>
                        <th>Stadium</th>
                        <th>City</th>
                        <th>Sale</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Matches)
                    {
                        <tr>
                            <td data-order="@m.MatchDate.Ticks" style="white-space:nowrap">
                                <strong>@m.MatchDate.ToString("dd/MM/yyyy")</strong>
                                <small class="text-muted d-block">@m.MatchDate.ToString("HH:mm") UTC</small>
                            </td>
                            <td>
                                @{
                                    var pc = m.Phase switch {
                                        "Final"         => "danger",
                                        "Semi-Final"    => "warning text-dark",
                                        "Quarter-Final" => "info text-dark",
                                        _               => "secondary"
                                    };
                                }
                                <span class="badge bg-@pc">@m.Phase</span>
                            </td>
                            <td class="fw-semibold">
                                <img src="@m.HomeClubBadge" alt="" style="height:22px;width:22px;object-fit:contain;margin-right:6px"
                                     onerror="this.style.display='none'" />
                                @m.HomeClubName
                            </td>
                            <td class="text-muted">
                                <img src="@m.AwayClubBadge" alt="" style="height:22px;width:22px;object-fit:contain;margin-right:6px"
                                     onerror="this.style.display='none'" />
                                @m.AwayClubName
                            </td>
                            <td class="text-muted small">@m.StadiumName</td>
                            <td class="text-muted small">@m.StadiumCity</td>
                            <td>
                                @if (m.IsSaleOpen)
                                {
                                    <span class="badge rounded-pill bg-success">
                                        <i class="bi bi-check-circle me-1"></i>@Tr.T("match_sale_open")
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-secondary">
                                        <i class="bi bi-lock me-1"></i>@Tr.T("match_sale_closed")
                                    </span>
                                }
                            </td>
                            <td>
                                <a asp-action="Detail" asp-route-id="@m.Id"
                                   class="btn btn-sm fw-semibold text-dark"
                                   style="background:#FFD700;border:none;white-space:nowrap">
                                    <i class="bi bi-ticket-perforated me-1"></i>@Tr.T("match_btn_tickets")
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script>
$(function () {
    $('#matchTable').DataTable({
        order: [[0, 'asc']],
        pageLength: 13,
        language: {
            search: '',
            searchPlaceholder: 'Search...',
            lengthMenu: 'Show _MENU_',
            info: '_START_–_END_ / _TOTAL_',
            paginate: { next: 'Next ›', previous: '‹ Prev' }
        },
        dom: '<"d-flex justify-content-between align-items-center px-3 py-2"lf>t<"d-flex justify-content-between align-items-center px-3 py-2"ip>',
    });
});
</script>
}
