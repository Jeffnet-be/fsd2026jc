@model ChampionsLeague.Web.ViewModels.MatchListVM
@{
    ViewData["Title"] = "Match Calendar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">📅 Match Calendar</h1>
    @if (Model.FilterClub != null)
    {
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            ✕ Clear filter: @Model.FilterClub
        </a>
    }
</div>

@*
    jQuery DataTables: ordering, searching, and paging built-in.
    Curriculum section 10.4.3 — client-side library for table enhancement.
    No extra controller actions needed — all sorting/filtering happens in the browser.
*@
<table id="matchTable" class="table table-hover table-striped align-middle">
    <thead class="table-dark">
        <tr>
            <th>Date &amp; Time</th>
            <th>Phase</th>
            <th>Home</th>
            <th>Away</th>
            <th>Stadium</th>
            <th>City</th>
            <th>Sale</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model.Matches)
        {
            <tr>
                <td data-order="@m.MatchDate.Ticks">
                    @m.MatchDate.ToString("dd/MM/yyyy")
                    <small class="text-muted d-block">@m.MatchDate.ToString("HH:mm") UTC</small>
                </td>
                <td>
                    <span class="badge bg-secondary">@m.Phase</span>
                </td>
                <td>
                    <img src="@m.HomeClubBadge" alt="" style="height:22px"
                         onerror="this.style.display='none'" />
                    @m.HomeClubName
                </td>
                <td>
                    <img src="@m.AwayClubBadge" alt="" style="height:22px"
                         onerror="this.style.display='none'" />
                    @m.AwayClubName
                </td>
                <td>@m.StadiumName</td>
                <td>@m.StadiumCity</td>
                <td>
                    @if (m.IsSaleOpen)
                    {
                        <span class="badge bg-success">🟢 Open</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">🔴 Closed</span>
                    }
                </td>
                <td>
                    <a asp-action="Detail" asp-route-id="@m.Id"
                       class="btn btn-warning btn-sm">
                        Tickets
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
<script>
    $(document).ready(function () {
        $('#matchTable').DataTable({
            order: [[0, 'asc']],
            pageLength: 13,
            language: {
                search: 'Search:',
                lengthMenu: 'Show _MENU_ matches',
                info: 'Showing _START_ to _END_ of _TOTAL_ matches',
                paginate: { next: 'Next ›', previous: '‹ Prev' }
            }
        });
    });
</script>
}
