@model ChampionsLeague.Web.ViewModels.MatchDetailVM
@{ ViewData["Title"] = $"{Model.HomeClubName} vs {Model.AwayClubName}"; }

<div class="container py-4">
<!-- Match header -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-center align-items-center gap-5 flex-wrap py-2">
            <div class="text-center">
                <img src="@Model.HomeClubBadge" alt="@Model.HomeClubName" style="height:80px" onerror="this.style.display='none'" />
                <h4 class="mt-2 fw-bold">@Model.HomeClubName</h4>
                <small class="text-muted">@Tr.T("detail_home")</small>
            </div>
            <div class="text-center">
                <h2 class="display-6 fw-bold text-muted">vs</h2>
                <span class="badge bg-secondary">@Model.Phase</span>
            </div>
            <div class="text-center">
                <img src="@Model.AwayClubBadge" alt="@Model.AwayClubName" style="height:80px" onerror="this.style.display='none'" />
                <h4 class="mt-2 fw-bold">@Model.AwayClubName</h4>
                <small class="text-muted">@Tr.T("detail_away")</small>
            </div>
        </div>
        <hr />
        <p class="text-center mb-0 text-muted">
            📅 @Model.MatchDate.ToString("dddd, dd MMMM yyyy") @Model.MatchDate.ToString("HH:mm") UTC
            &nbsp;|&nbsp; 🏟️ @Model.StadiumName, @Model.StadiumCity
        </p>
    </div>
</div>

    @if (!Model.IsSaleOpen && DateTime.UtcNow < Model.MatchDate)
{
    <div class="alert alert-warning d-flex align-items-center gap-2">
        <span style="font-size:1.5rem">🔒</span>
        <div>
                <strong>@Tr.T("detail_match_past")</strong>
        </div>
    </div>
}
else if (!Model.IsSaleOpen && DateTime.UtcNow >= Model.MatchDate.AddMonths(-1))
{
    <div class="alert alert-warning d-flex align-items-center gap-2">
        <span style="font-size:1.5rem">🔒</span>
        <div>
            <strong>@Tr.T("detail_sale_closed")</strong>
            @Tr.T("detail_sale_opens") <strong>@Model.MatchDate.AddMonths(-1).ToString("dd/MM/yyyy")</strong>.
        </div>
    </div>
}
else
{
    <div id="purchase-feedback" class="mb-3"></div>
    <h3 class="mb-3 fw-bold" style="color:#001489">🎟️ @Tr.T("detail_select_sector")</h3>

    <div class="row row-cols-1 row-cols-md-2 g-3 mb-4">
        @foreach (var sec in Model.Sectors)
        {
            <div class="col">
                <div class="card h-100 border-@(sec.Available > 0 ? "success" : "danger") @(sec.Available == 0 ? "opacity-75" : "")">
                    <div class="card-body">
                        <h6 class="card-title fw-bold">@Tr.TranslateSector(sec.SectorName)</h6>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">
                                @Tr.T("detail_available"): <strong>@sec.Available</strong> / @sec.Capacity
                            </span>
                            <span class="fw-bold text-success">
                                € @sec.Price.ToString("0.00") / @Tr.T("detail_per_ticket")
                            </span>
                        </div>
                        <div class="progress mb-3" style="height:6px">
                            @{ var pct = sec.Capacity > 0 ? (int)((double)sec.Available / sec.Capacity * 100) : 0;
                               var bc  = pct > 40 ? "bg-success" : pct > 15 ? "bg-warning" : "bg-danger"; }
                            <div class="progress-bar @bc" style="width:@pct%"></div>
                        </div>
                        @if (sec.Available > 0)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <select class="form-select form-select-sm w-auto qty-select"
                                        data-matchid="@Model.Id"
                                        data-sectorid="@sec.SectorId"
                                        data-price="@sec.Price.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                        data-matchdesc="@Model.HomeClubName vs @Model.AwayClubName"
                                        data-matchdate="@Model.MatchDate.ToString("o")"
                                        data-sectorname="@sec.SectorName">
                                    @for (int q = 1; q <= Math.Min(4, sec.Available); q++)
                                    {
                                        <option value="@q">@q @(q > 1 ? Tr.T("detail_tickets_pl") : Tr.T("detail_ticket_s"))</option>
                                    }
                                </select>
                                <button class="btn btn-warning btn-sm fw-semibold add-to-cart-btn">
                                    🛒 @Tr.T("detail_add_cart")
                                </button>
                            </div>
                        }
                        else
                        {
                            <span class="badge bg-danger">@Tr.T("detail_sold_out")</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a asp-controller="Hotel" asp-action="Search" asp-route-city="@Model.StadiumCity"
           class="btn btn-outline-secondary">
            🏨 @Tr.T("detail_find_hotels") @Model.StadiumCity
        </a>
        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-dark">
            🛒 @Tr.T("detail_view_cart")
        </a>
    </div>
}
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        $(function () {
            $('.add-to-cart-btn').on('click', function () {
                var btn = $(this), sel = btn.closest('.d-flex').find('.qty-select');
                var item = {
                    matchId:          parseInt(sel.data('matchid')),
                    matchDescription: sel.data('matchdesc'),
                    matchDate:        sel.data('matchdate'),
                    sectorId:         parseInt(sel.data('sectorid')),
                    sectorName:       sel.data('sectorname'),
                    quantity:         parseInt(sel.val()),
                    unitPrice:        parseFloat(sel.data('price'))
                };
                btn.prop('disabled', true).text('...');
                $.ajax({
                    url: '/Cart/AddToCart', method: 'POST', contentType: 'application/json',
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    data: JSON.stringify(item),
                    success: function(html) {
                        var count = $(html).filter('#cart-count').text() || $(html).find('#cart-count').text();
                        $('#cart-badge').text(count);
                        $('#purchase-feedback').html('<div class="alert alert-success alert-dismissible fade show">✅ @Tr.T("detail_added") <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
                        btn.prop('disabled', false).html('🛒 @Tr.T("detail_add_cart")');
                    },
                    error: function(xhr) {
                        var msg = (xhr.responseJSON && xhr.responseJSON.error) ? xhr.responseJSON.error : 'Error. Please try again.';
                        $('#purchase-feedback').html('<div class="alert alert-danger">' + msg + '</div>');
                        btn.prop('disabled', false).html('🛒 @Tr.T("detail_add_cart")');
                    }
                });
            });
        });
    </script>
}
