<!DOCTYPE html>
<html lang="@System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – CL Tickets</title>

    <!-- Bootstrap 5.3 from CDN — no local lib folder needed -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css"
          integrity="sha512-jnSoA9Po7t5a0N9DdNk/5nGO7p3Bw/N9cMRnI7vIBbEynCU6KBIZEXjXPf7jLaBRgCHZrtQHB1hHGWVkfZA=="
          crossorigin="anonymous" />

    <!-- DataTables from CDN -->
    <link rel="stylesheet"
          href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

<!-- ── Navbar ─────────────────────────────────────────────────────── -->
<nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="background:#001489">
    <div class="container">
        <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
            ⚽ <span style="color:#FFD700">CL</span> Tickets
        </a>
        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-fill me-1"></i>Home
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Matches" asp-action="Index">
                        <i class="bi bi-calendar3 me-1"></i>Matches
                    </a>
                </li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Account" asp-action="MyTickets">
                            <i class="bi bi-ticket-perforated me-1"></i>My Tickets
                        </a>
                    </li>
                }
            </ul>

            <ul class="navbar-nav ms-auto align-items-center gap-1">
                <!-- Language -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle text-white" href="#" data-bs-toggle="dropdown">
                        🌐
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        <li><a class="dropdown-item" href="?culture=nl">🇧🇪 Nederlands</a></li>
                        <li><a class="dropdown-item" href="?culture=fr">🇫🇷 Français</a></li>
                        <li><a class="dropdown-item" href="?culture=en">🇬🇧 English</a></li>
                    </ul>
                </li>

                <!-- Cart -->
                <li class="nav-item">
                    <a class="nav-link position-relative px-2" asp-controller="Cart" asp-action="Index">
                        <i class="bi bi-cart3 fs-5 text-white"></i>
                        <span class="position-absolute top-0 start-100 translate-middle
                                     badge rounded-pill bg-warning text-dark"
                              id="cart-badge" style="font-size:.65rem">0</span>
                    </a>
                </li>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <span class="navbar-text text-warning fw-semibold small me-1">
                            <i class="bi bi-person-fill"></i> @User.Identity.Name
                        </span>
                    </li>
                    <li class="nav-item">
                        <form asp-controller="Account" asp-action="Logout"
                              method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-light btn-sm">
                                <i class="bi bi-box-arrow-right me-1"></i>Logout
                            </button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm"
                           asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-sm fw-bold" style="background:#FFD700;color:#001489"
                           asp-controller="Account" asp-action="Register">Register</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<!-- ── Page content ───────────────────────────────────────────────── -->
<main class="flex-grow-1">
    @RenderBody()
</main>

<!-- ── Footer ────────────────────────────────────────────────────── -->
<footer style="background:#001489" class="text-white py-4 mt-auto">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <span class="fw-bold fs-5">⚽ <span style="color:#FFD700">CL</span> Tickets</span>
                <p class="text-white-50 small mb-0 mt-1">
                    Official ticket portal for Champions League matches
                </p>
            </div>
            <div class="col-md-6 text-md-end mt-3 mt-md-0">
                <small class="text-white-50">
                    &copy; @DateTime.Now.Year Champions League Ticket Portal<br />
                    VIVES Hogeschool &mdash; Full Stack Development
                </small>
            </div>
        </div>
    </div>
</footer>

<!-- ── Scripts — all from CDN, no local lib needed ───────────────── -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"
        crossorigin="anonymous"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"
        crossorigin="anonymous"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
