<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – CL Tickets</title>

    <!-- Bootstrap 5.3 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" crossorigin="anonymous" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet" crossorigin="anonymous" />
    <!-- DataTables + Bootstrap5 theme -->
    <link href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css"
          rel="stylesheet" />

    <style>
        :root { --cl-navy:#001489; --cl-gold:#FFD700; }
        body  { font-family:'Segoe UI',system-ui,sans-serif; background:#f4f6fb; }
        .navbar-cl { background:var(--cl-navy); }
        .navbar-cl .nav-link        { color:rgba(255,255,255,.85)!important; font-weight:500; }
        .navbar-cl .nav-link:hover  { color:var(--cl-gold)!important; }
        .navbar-cl .navbar-brand    { color:#fff!important; font-weight:700; font-size:1.3rem; }
        .btn-gold { background:var(--cl-gold); color:var(--cl-navy); font-weight:700; border:none; }
        .btn-gold:hover { background:#e6c200; color:var(--cl-navy); }
        .card { border-radius:14px!important; }
        .card:hover { transform:translateY(-4px); box-shadow:0 8px 24px rgba(0,0,0,.12)!important; transition:.2s; }
        table.dataTable thead th { background:var(--cl-navy)!important; color:#fff!important; border-color:#0022bb!important; white-space:nowrap; }
        .dataTables_wrapper .dataTables_filter input,
        .dataTables_wrapper .dataTables_length select { border:1px solid #ced4da; border-radius:6px; padding:3px 8px; }
        footer a { color:rgba(255,255,255,.6); text-decoration:none; }
        footer a:hover { color:var(--cl-gold); }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

<!-- ── Navbar ─────────────────────────────────────────────── -->
<nav class="navbar navbar-expand-lg navbar-cl shadow-sm">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            ⚽ <span style="color:var(--cl-gold)">CL</span> Tickets
        </a>
        <button class="navbar-toggler border-secondary" type="button"
                data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="nav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-fill me-1"></i>Home
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Matches" asp-action="Index">
                        <i class="bi bi-calendar3 me-1"></i>Matches
                    </a>
                </li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="MyTickets">
                            <i class="bi bi-ticket-perforated me-1"></i>My Tickets
                        </a>
                    </li>
                }
            </ul>

            <ul class="navbar-nav ms-auto align-items-center gap-2">

                <!-- Language — preserves current path, just sets cookie -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        🌐 Language
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                        <li>
                            <a class="dropdown-item" href="#"
                               onclick="setLang('nl');return false;">
                                🇧🇪 Nederlands
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="#"
                               onclick="setLang('fr');return false;">
                                🇫🇷 Français
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item" href="#"
                               onclick="setLang('en');return false;">
                                🇬🇧 English
                            </a>
                        </li>
                    </ul>
                </li>

                <!-- Cart -->
                <li class="nav-item">
                    <a class="nav-link position-relative px-2"
                       asp-controller="Cart" asp-action="Index">
                        <i class="bi bi-cart3 fs-5"></i>
                        <span class="position-absolute top-0 start-100 translate-middle
                                     badge rounded-pill bg-warning text-dark"
                              id="cart-badge" style="font-size:.65rem">0</span>
                    </a>
                </li>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item d-none d-lg-block">
                        <span class="navbar-text text-warning small fw-semibold">
                            <i class="bi bi-person-fill me-1"></i>@User.Identity.Name
                        </span>
                    </li>
                    <li class="nav-item">
                        <form asp-controller="Account" asp-action="Logout"
                              method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-light btn-sm">
                                <i class="bi bi-box-arrow-right me-1"></i>Logout
                            </button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm"
                           asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-gold btn-sm"
                           asp-controller="Account" asp-action="Register">Register</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<!-- ── Main content ───────────────────────────────────────── -->
<main class="flex-grow-1">
    @RenderBody()
</main>

<!-- ── Footer ─────────────────────────────────────────────── -->
<footer class="navbar-cl text-white py-4 mt-auto">
    <div class="container">
        <div class="row align-items-center gy-2">
            <div class="col-md-6">
                <div class="fw-bold fs-5 mb-1">
                    ⚽ <span style="color:var(--cl-gold)">CL</span> Tickets
                </div>
                <small class="text-white-50">
                    Official Champions League ticket portal
                </small>
            </div>
            <div class="col-md-6 text-md-end">
                <small class="text-white-50">
                    &copy; @DateTime.Now.Year Champions League Ticket Portal<br/>
                    VIVES Hogeschool — Full Stack Development
                </small>
            </div>
        </div>
    </div>
</footer>

<!-- ── Scripts ─────────────────────────────────────────────── -->
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"
        crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        crossorigin="anonymous"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>

<script>
    // Language switcher: sets a cookie and reloads the current page
    // so the URL stays the same but the culture changes.
    function setLang(culture) {
        document.cookie = '.AspNetCore.Culture=c=' + culture + '|uic=' + culture
            + ';path=/;max-age=31536000';
        window.location.reload();
    }
</script>

<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
