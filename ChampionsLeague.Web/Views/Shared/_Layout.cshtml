<!DOCTYPE html>
<html lang="@Tr.Culture">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – CL Tickets</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" crossorigin="anonymous" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet" crossorigin="anonymous" />
    <link href="https://cdn.datatables.net/1.13.8/css/dataTables.bootstrap5.min.css"
          rel="stylesheet" />
    <style>
        :root { --navy:#001489; --gold:#FFD700; }
        body  { font-family:'Segoe UI',system-ui,sans-serif; background:#f4f6fb; }
        .cl-nav { background:var(--navy)!important; }
        .cl-nav .navbar-brand { color:#fff!important; font-weight:700; font-size:1.25rem; }
        .cl-nav .nav-link     { color:rgba(255,255,255,.85)!important; font-weight:500; padding:.5rem .75rem!important; }
        .cl-nav .nav-link:hover,
        .cl-nav .nav-link:focus { color:var(--gold)!important; }
        .cl-nav .dropdown-menu { border:none; box-shadow:0 4px 16px rgba(0,0,0,.15); border-radius:10px; }
        .cl-nav .dropdown-item:hover { background:#f0f4ff; color:var(--navy); }
        .btn-gold { background:var(--gold)!important; color:var(--navy)!important; font-weight:700!important; border:none!important; }
        .btn-gold:hover { background:#e6c200!important; color:var(--navy)!important; }
        .btn { border-radius:8px!important; }
        .card { border-radius:14px!important; transition:.2s!important; }
        .card:hover { transform:translateY(-4px)!important; box-shadow:0 10px 28px rgba(0,0,0,.13)!important; }
        table.dataTable thead th,
        table.dataTable thead td { background:var(--navy)!important; color:#fff!important; border-color:#1a2eaa!important; white-space:nowrap; }
        table.dataTable thead .sorting:after,
        table.dataTable thead .sorting_asc:after,
        table.dataTable thead .sorting_desc:after { color:rgba(255,255,255,.5)!important; }
        .dataTables_wrapper .dataTables_filter input,
        .dataTables_wrapper .dataTables_length select { border:1px solid #ced4da; border-radius:6px; padding:3px 10px; }
        code { background:#eef2ff; padding:2px 7px; border-radius:5px; font-size:.82rem; color:#c0392b; }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg cl-nav shadow-sm">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            ⚽ <span style="color:var(--gold)">CL</span> Tickets
        </a>
        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house-fill me-1"></i>@Tr.T("nav_home")
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Matches" asp-action="Index">
                        <i class="bi bi-calendar3 me-1"></i>@Tr.T("nav_matches")
                    </a>
                </li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="MyTickets">
                            <i class="bi bi-ticket-perforated me-1"></i>@Tr.T("nav_mytickets")
                        </a>
                    </li>
                }
            </ul>
            <ul class="navbar-nav ms-auto align-items-center gap-2">
                <!-- Language switcher — server-side via CultureController -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#"
                       role="button" data-bs-toggle="dropdown">
                        🌐 @Tr.T("nav_language")
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item @(Tr.Culture == "nl" ? "fw-bold" : "")"
                               asp-controller="Culture" asp-action="Set"
                               asp-route-culture="nl"
                               asp-route-returnUrl="@Context.Request.Path">
                                🇧🇪 Nederlands
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item @(Tr.Culture == "fr" ? "fw-bold" : "")"
                               asp-controller="Culture" asp-action="Set"
                               asp-route-culture="fr"
                               asp-route-returnUrl="@Context.Request.Path">
                                🇫🇷 Français
                            </a>
                        </li>
                        <li>
                            <a class="dropdown-item @(Tr.Culture == "en" ? "fw-bold" : "")"
                               asp-controller="Culture" asp-action="Set"
                               asp-route-culture="en"
                               asp-route-returnUrl="@Context.Request.Path">
                                🇬🇧 English
                            </a>
                        </li>
                    </ul>
                </li>
                <!-- Cart -->
                <li class="nav-item">
                    <a class="nav-link position-relative px-2"
                       asp-controller="Cart" asp-action="Index">
                        <i class="bi bi-cart3 fs-5 text-white"></i>
                        <span class="position-absolute top-0 start-100 translate-middle
                                     badge rounded-pill bg-warning text-dark"
                              id="cart-badge" style="font-size:.65rem">0</span>
                    </a>
                </li>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item d-none d-lg-block">
                        <span class="navbar-text small fw-semibold" style="color:var(--gold)">
                            <i class="bi bi-person-fill me-1"></i>@User.Identity.Name
                        </span>
                    </li>
                    <li class="nav-item">
                        <form asp-controller="Account" asp-action="Logout"
                              method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-light btn-sm">
                                <i class="bi bi-box-arrow-right me-1"></i>@Tr.T("nav_logout")
                            </button>
                        </form>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm"
                           asp-controller="Account" asp-action="Login">@Tr.T("nav_login")</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-gold btn-sm"
                           asp-controller="Account" asp-action="Register">@Tr.T("nav_register")</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="flex-grow-1">
    @RenderBody()
</main>

<footer class="cl-nav text-white py-4 mt-auto">
    <div class="container">
        <div class="row align-items-center gy-2">
            <div class="col-md-6">
                <div class="fw-bold fs-5 mb-1">⚽ <span style="color:var(--gold)">CL</span> Tickets</div>
                <small class="text-white-50">@Tr.T("footer_tagline")</small>
            </div>
            <div class="col-md-6 text-md-end">
                <small class="text-white-50">
                    &copy; @DateTime.Now.Year Champions League Ticket Portal<br/>
                    VIVES Hogeschool &mdash; Full Stack Development
                </small>
            </div>
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
<script src="https://cdn.datatables.net/1.13.8/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.8/js/dataTables.bootstrap5.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
