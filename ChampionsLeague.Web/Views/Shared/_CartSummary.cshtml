@model ChampionsLeague.Web.ViewModels.CartVM
@*
    Partial view returned by CartController.AddToCart (AJAX response).
    The JavaScript on the match detail page reads cart-count to update
    the navbar badge without a full page reload.
    Count includes both regular tickets AND season items.
*@
<span id="cart-count">@Model.Count</span>
<span id="cart-total">@Model.Total.ToString("0.00")</span>
