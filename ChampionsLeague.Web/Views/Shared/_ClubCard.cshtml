@model ChampionsLeague.Web.ViewModels.ClubCardVM
<div class="col">
    <div class="card border-0 shadow-sm h-100"
         style="border-radius:14px;overflow:hidden;transition:.2s">
        <div class="text-center py-4" style="background:@Model.PrimaryColor">
            <div class="mx-auto rounded-circle bg-white d-flex align-items-center justify-content-center shadow mb-2"
                 style="width:68px;height:68px">
                <img src="@Model.BadgeUrl" alt="@Model.Name"
                     style="width:52px;height:52px;object-fit:contain"
                     onerror="this.parentElement.innerHTML='<span style=font-size:1.8rem;font-weight:700>@Model.Name[0]</span>'" />
            </div>
            <h5 class="fw-bold mb-0 px-3"
                style="color:#fff;text-shadow:0 1px 4px rgba(0,0,0,.5)">
                @Model.Name
            </h5>
        </div>
        <div class="card-body bg-white px-4 pt-3 pb-2">
            <div class="small text-muted mb-1">
                <i class="bi bi-geo-alt-fill me-1" style="color:@Model.PrimaryColor"></i>@Model.Country
                &nbsp;·&nbsp;
                <i class="bi bi-building me-1" style="color:@Model.PrimaryColor"></i>@Model.StadiumName, @Model.StadiumCity
            </div>
            <div class="mb-3">
                <span class="badge text-white rounded-pill px-3"
                      style="background:@Model.PrimaryColor">
                    <i class="bi bi-people-fill me-1"></i>
                    @Model.TotalCapacity.ToString("N0") @Tr.T("club_seats")
                </span>
            </div>
            <table class="table table-sm table-striped mb-0" style="font-size:.78rem">
                <thead class="table-dark">
                    <tr>
                        <th>@Tr.T("club_col_sector")</th>
                        <th class="text-end">@Tr.T("club_col_seats")</th>
                        <th class="text-end">@Tr.T("club_col_from")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Sectors)
                    {
                        <tr>
                            <td class="text-muted"
                                style="max-width:150px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                @Tr.TranslateSector(s.Name)
                            </td>
                            <td class="text-end">@s.Capacity.ToString("N0")</td>
                            <td class="text-end fw-semibold" style="color:@Model.PrimaryColor">
                                @s.BasePrice.ToString("0.00")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-white border-0 px-4 pb-4 pt-0">
            <a asp-controller="Matches" asp-action="Index"
               asp-route-clubId="@Model.Id"
               class="btn w-100 fw-semibold text-white"
               style="background:@Model.PrimaryColor;border:none;border-radius:8px">
                <i class="bi bi-calendar3 me-2"></i>@Tr.T("club_view_fixtures")
            </a>
        </div>
    </div>
</div>
