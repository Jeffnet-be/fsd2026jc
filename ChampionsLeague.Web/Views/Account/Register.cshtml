@model ChampionsLeague.Web.ViewModels.RegisterVM
@{ ViewData["Title"] = Tr.T("reg_title"); }

<div class="container py-4">
<div class="row justify-content-center">
<div class="col-md-6 col-lg-5">
<div class="card border-0 shadow">
    <div class="card-header text-white text-center py-3" style="background:#001489">
        <h4 class="mb-0">⚽ @Tr.T("reg_title")</h4>
        <small style="color:#FFD700">@Tr.T("reg_subtitle")</small>
    </div>
    <div class="card-body p-4">

        @* Identity errors (e.g. duplicate email) — only shown after submit *@
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
        {
            <div class="alert alert-danger py-2 small">
                @foreach (var error in ViewData.ModelState[""]!.Errors)
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        @* Password requirements — always visible before submitting *@
        <div class="border rounded-3 p-3 mb-4" style="background:#f8f9ff">
            <div class="fw-semibold mb-2 small" style="color:#001489">
                <i class="bi bi-shield-lock me-1"></i>@Tr.T("reg_pwd_requirements_title")
            </div>
            <ul class="mb-0 ps-3 small" style="line-height:2">
                <li id="req-length" ><i class="bi bi-circle me-1 text-muted"></i>@Tr.T("reg_pwd_req_length")</li>
                <li id="req-digit"  ><i class="bi bi-circle me-1 text-muted"></i>@Tr.T("reg_pwd_req_digit")</li>
                <li id="req-upper"  ><i class="bi bi-circle me-1 text-muted"></i>@Tr.T("reg_pwd_req_upper")</li>
                <li id="req-lower"  ><i class="bi bi-circle me-1 text-muted"></i>@Tr.T("reg_pwd_req_lower")</li>
                <li id="req-special"><i class="bi bi-circle me-1 text-muted"></i>@Tr.T("reg_pwd_req_special")</li>
                <li id="req-match"  ><i class="bi bi-circle me-1 text-muted"></i>@Tr.T("reg_pwd_req_match")</li>
            </ul>
        </div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label fw-semibold">@Tr.T("reg_firstname")</label>
                    <input asp-for="FirstName" class="form-control" placeholder="Jan" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-6">
                    <label class="form-label fw-semibold">@Tr.T("reg_lastname")</label>
                    <input asp-for="LastName" class="form-control" placeholder="Peeters" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">@Tr.T("reg_email")</label>
                <input asp-for="Email" class="form-control"
                       placeholder="jan.peeters@@example.com"
                       autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">@Tr.T("reg_password")</label>
                <div class="input-group">
                    <input asp-for="Password" class="form-control"
                           id="pwd-input"
                           placeholder="bijv. Voetbal@2025!!"
                           autocomplete="new-password" />
                    <button class="btn btn-outline-secondary" type="button"
                            onclick="togglePwd('pwd-input', this)">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>

                <!-- Strength bar -->
                <div class="mt-2">
                    <div class="progress" style="height:6px;border-radius:4px;background:#e9ecef">
                        <div id="pwd-strength-bar" class="progress-bar"
                             style="width:0%;transition:width .3s,background .3s;border-radius:4px"></div>
                    </div>
                    <small id="pwd-strength-label" class="text-muted"></small>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">@Tr.T("reg_confirm")</label>
                <div class="input-group">
                    <input asp-for="ConfirmPassword" class="form-control"
                           id="confirm-input"
                           placeholder="Herhaal uw wachtwoord"
                           autocomplete="new-password" />
                    <button class="btn btn-outline-secondary" type="button"
                            onclick="togglePwd('confirm-input', this)">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn w-100 fw-bold py-2"
                    style="background:#FFD700;color:#001489;border:none;border-radius:8px">
                @Tr.T("reg_btn")
            </button>
        </form>
    </div>
    <div class="card-footer bg-white text-center py-3">
        @Tr.T("reg_have_account")
        <a asp-action="Login" class="fw-semibold">@Tr.T("reg_login_link")</a>
    </div>
</div>
</div>
</div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
function togglePwd(id, btn) {
    var input = document.getElementById(id);
    var icon  = btn.querySelector('i');
    input.type     = input.type === 'password' ? 'text' : 'password';
    icon.className = input.type === 'text' ? 'bi bi-eye-slash' : 'bi bi-eye';
}

function setReq(id, met) {
    var li = document.getElementById(id);
    var i  = li.querySelector('i');
    if (met) {
        i.className    = 'bi bi-check-circle-fill me-1 text-success';
        li.style.color = '#198754';
    } else {
        i.className    = 'bi bi-circle me-1 text-muted';
        li.style.color = '';
    }
}

document.getElementById('pwd-input').addEventListener('input', function () {
    var pwd = this.value;

    var hasLength  = pwd.length >= 12;
    var hasDigit   = /[0-9]/.test(pwd);
    var hasUpper   = /[A-Z]/.test(pwd);
    var hasLower   = /[a-z]/.test(pwd);
    var hasSpecial = /[^A-Za-z0-9]/.test(pwd);
    var hasMatch   = pwd.length > 0 && pwd === document.getElementById('confirm-input').value;

    setReq('req-length',  hasLength);
    setReq('req-digit',   hasDigit);
    setReq('req-upper',   hasUpper);
    setReq('req-lower',   hasLower);
    setReq('req-special', hasSpecial);
    setReq('req-match',   hasMatch);

    // Strength = how many of the 5 rules are met
    var score = [hasLength, hasDigit, hasUpper, hasLower, hasSpecial].filter(Boolean).length;
    var levels = [
        { w:'0%',   bg:'',        text:'' },
        { w:'20%',  bg:'#e74c3c', text:'@Tr.T("reg_pwd_weak")' },
        { w:'40%',  bg:'#e67e22', text:'@Tr.T("reg_pwd_weak")' },
        { w:'60%',  bg:'#f39c12', text:'@Tr.T("reg_pwd_fair")' },
        { w:'80%',  bg:'#3498db', text:'@Tr.T("reg_pwd_good")' },
        { w:'100%', bg:'#27ae60', text:'@Tr.T("reg_pwd_strong")' },
    ];
    var bar = document.getElementById('pwd-strength-bar');
    var lbl = document.getElementById('pwd-strength-label');
    bar.style.width      = levels[score].w;
    bar.style.background = levels[score].bg;
    lbl.textContent      = levels[score].text;
    lbl.style.color      = levels[score].bg;
});

document.getElementById('confirm-input').addEventListener('input', function () {
    var pwd = document.getElementById('pwd-input').value;
    setReq('req-match', this.value.length > 0 && this.value === pwd);
});
</script>
}
