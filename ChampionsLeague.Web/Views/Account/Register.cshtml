@model ChampionsLeague.Web.ViewModels.RegisterVM
@{ ViewData["Title"] = Tr.T("reg_title"); }

<div class="container py-4">
<div class="row justify-content-center">
<div class="col-md-6 col-lg-5">
<div class="card border-0 shadow">
    <div class="card-header text-white text-center py-3" style="background:#001489">
        <h4 class="mb-0">⚽ @Tr.T("reg_title")</h4>
        <small style="color:#FFD700">@Tr.T("reg_subtitle")</small>
    </div>
    <div class="card-body p-4">

        @* Identity errors (e.g. duplicate email) — only shown after submit *@
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState[""]?.Errors.Count > 0)
        {
            <div class="alert alert-danger py-2 small">
                @foreach (var error in ViewData.ModelState[""]!.Errors)
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        @* Password requirements — always visible to guide the user before submitting *@
        <div class="alert alert-light border small mb-4 py-2 px-3" style="border-radius:8px">
            <div class="fw-semibold mb-1" style="color:#001489">
                <i class="bi bi-shield-lock me-1"></i>@Tr.T("reg_pwd_requirements_title")
            </div>
            <ul class="mb-0 ps-3">
                <li>@Tr.T("reg_pwd_req_length")</li>
                <li>@Tr.T("reg_pwd_req_digit")</li>
                <li>@Tr.T("reg_pwd_req_match")</li>
            </ul>
        </div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            <div class="row g-3 mb-3">
                <div class="col-6">
                    <label class="form-label fw-semibold">@Tr.T("reg_firstname")</label>
                    <input asp-for="FirstName" class="form-control"
                           placeholder="Jan" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>
                <div class="col-6">
                    <label class="form-label fw-semibold">@Tr.T("reg_lastname")</label>
                    <input asp-for="LastName" class="form-control"
                           placeholder="Peeters" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">@Tr.T("reg_email")</label>
                <input asp-for="Email" class="form-control"
                       placeholder="jan.peeters@example.com"
                       autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">@Tr.T("reg_password")</label>
                <div class="input-group">
                    <input asp-for="Password" class="form-control"
                           id="pwd-input"
                           placeholder="Min. 8 tekens, incl. 1 cijfer"
                           autocomplete="new-password" />
                    <button class="btn btn-outline-secondary" type="button"
                            onclick="togglePwd('pwd-input', this)"
                            title="Show/hide password">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>

                @* Live strength indicator *@
                <div class="mt-2">
                    <div class="progress" style="height:5px;border-radius:4px">
                        <div id="pwd-strength-bar" class="progress-bar"
                             style="width:0%;transition:width .3s,background .3s"></div>
                    </div>
                    <small id="pwd-strength-label" class="text-muted"></small>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label fw-semibold">@Tr.T("reg_confirm")</label>
                <div class="input-group">
                    <input asp-for="ConfirmPassword" class="form-control"
                           id="confirm-input"
                           placeholder="Herhaal uw wachtwoord"
                           autocomplete="new-password" />
                    <button class="btn btn-outline-secondary" type="button"
                            onclick="togglePwd('confirm-input', this)"
                            title="Show/hide password">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn w-100 fw-bold py-2"
                    style="background:#FFD700;color:#001489;border:none;border-radius:8px">
                @Tr.T("reg_btn")
            </button>
        </form>
    </div>
    <div class="card-footer bg-white text-center py-3">
        @Tr.T("reg_have_account")
        <a asp-action="Login" class="fw-semibold">@Tr.T("reg_login_link")</a>
    </div>
</div>
</div>
</div>
</div>

@section Scripts {
<partial name="_ValidationScriptsPartial" />
<script>
// ── Show/hide password toggle ─────────────────────────────────────────
function togglePwd(inputId, btn) {
    var input = document.getElementById(inputId);
    var icon  = btn.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye-slash';
    } else {
        input.type = 'password';
        icon.className = 'bi bi-eye';
    }
}

// ── Password strength meter ───────────────────────────────────────────
document.getElementById('pwd-input').addEventListener('input', function () {
    var pwd = this.value;
    var score = 0;
    if (pwd.length >= 8)  score++;
    if (pwd.length >= 12) score++;
    if (/[0-9]/.test(pwd)) score++;
    if (/[A-Z]/.test(pwd)) score++;
    if (/[^A-Za-z0-9]/.test(pwd)) score++;

    var bar   = document.getElementById('pwd-strength-bar');
    var label = document.getElementById('pwd-strength-label');

    var levels = [
        { w:'0%',   bg:'',          text:'' },
        { w:'25%',  bg:'#e74c3c',   text:'@Tr.T("reg_pwd_weak")' },
        { w:'50%',  bg:'#f39c12',   text:'@Tr.T("reg_pwd_fair")' },
        { w:'75%',  bg:'#3498db',   text:'@Tr.T("reg_pwd_good")' },
        { w:'100%', bg:'#27ae60',   text:'@Tr.T("reg_pwd_strong")' },
    ];

    var lvl = Math.min(score, 4);
    bar.style.width      = levels[lvl].w;
    bar.style.background = levels[lvl].bg;
    label.textContent    = levels[lvl].text;
    label.style.color    = levels[lvl].bg;
});
</script>
}
