@model IEnumerable<ChampionsLeague.Web.ViewModels.TicketHistoryItemVM>
@{ ViewData["Title"] = Tr.T("tickets_title"); }

<div class="container py-4">
<h1 class="fw-bold mb-4" style="color:#001489">🎫 @Tr.T("tickets_title")</h1>

@if (TempData["Success"] is string success)
{
    <div class="alert alert-success alert-dismissible fade show">
        ✅ @success <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string error)
{
    <div class="alert alert-danger alert-dismissible fade show">
        ⚠️ @error <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info d-flex align-items-center gap-3">
        <span style="font-size:2rem">🎟️</span>
        <div>@Tr.T("tickets_empty")</div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm" style="border-radius:14px;overflow:hidden">
        <table id="ticketTable" class="table table-hover table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>@Tr.T("tickets_col_match")</th>
                    <th>@Tr.T("tickets_col_date")</th>
                    <th>@Tr.T("tickets_col_sector")</th>
                    <th class="text-center">@Tr.T("tickets_col_seat")</th>
                    <th class="text-end">@Tr.T("tickets_col_price")</th>
                    <th class="text-center">@Tr.T("tickets_col_status")</th>
                    <th>@Tr.T("tickets_col_voucher")</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td class="fw-bold">@t.MatchDescription</td>
                        <td data-order="@t.MatchDate.Ticks">
                            @t.MatchDate.ToString("dd/MM/yyyy")
                            <small class="text-muted d-block">@t.MatchDate.ToString("HH:mm") UTC</small>
                        </td>
                        <td><small class="text-muted">@Tr.TranslateSector(t.SectorName)</small></td>
                        <td class="text-center">@t.SeatNumber</td>
                        <td class="text-end">€ @t.PricePaid.ToString("0.00")</td>
                        <td class="text-center">
                            @{ var bc = t.Status switch { "Paid"=>"success","Cancelled"=>"secondary",_=>"warning text-dark" }; }
                            <span class="badge bg-@bc">@t.Status</span>
                        </td>
                        <td>
                            @if (t.Status != "Cancelled")
                            {
                                <code class="small">@t.VoucherId.ToString("D")[..8]…</code>
                                <button class="btn btn-link btn-sm p-0 ms-1"
                                        onclick="navigator.clipboard.writeText('@t.VoucherId.ToString("D")')"
                                        title="@Tr.T("tickets_col_voucher")">📋</button>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-1">
                                @* Cancel button *@
                                @if (t.IsCancellable && t.Status == "Paid")
                                {
                                    <form asp-action="CancelTicket" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ticketId" value="@t.Id" />
                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm w-100"
                                                onclick="return confirm('@Tr.T("tickets_cancel_confirm")')">
                                            @Tr.T("tickets_cancel_btn")
                                        </button>
                                    </form>
                                }
                                else if (t.Status == "Paid")
                                {
                                    <small class="text-muted">@Tr.T("tickets_not_cancellable")</small>
                                }

                                @* Resend voucher button — only for Paid tickets *@
                                @if (t.Status == "Paid")
                                {
                                    <form asp-action="ResendVoucher" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ticketId" value="@t.Id" />
                                        <button type="submit"
                                                class="btn btn-outline-secondary btn-sm w-100">
                                            📧 @Tr.T("voucher_resend_btn")
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
</div>

@section Scripts {
<script>
$(function(){
    $('#ticketTable').DataTable({
        order:[[1,'desc']],
        pageLength:10,
        language:{ search:'', searchPlaceholder:'@Tr.T("match_col_date")...' }
    });
});
</script>
}
