@model IEnumerable<ChampionsLeague.Web.ViewModels.TicketHistoryItemVM>
@{
    ViewData["Title"] = Tr.T("tickets_title");
}

<div class="container py-4">
    <h1 class="fw-bold mb-4" style="color:#001489">🎫 @Tr.T("tickets_title")</h1>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success alert-dismissible fade show">
            ✅ @success <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] is string error)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            ⚠️ @error <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* ── Regular match tickets ─────────────────────────────────────────── *@
    <h2 class="fw-bold mb-3" style="color:#001489">🎟️ @Tr.T("tickets_title")</h2>
    @if (!Model.Any())
    {
        <div class="alert alert-info d-flex align-items-center gap-3">
            <span style="font-size:2rem">🎟️</span>
            <div>@Tr.T("tickets_empty")</div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm mb-5" style="border-radius:14px;overflow:hidden">
            <table id="ticketTable" class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>@Tr.T("tickets_col_match")</th>
                        <th>@Tr.T("tickets_col_date")</th>
                        <th>@Tr.T("tickets_col_sector")</th>
                        <th class="text-center">@Tr.T("tickets_col_seat")</th>
                        <th class="text-end">@Tr.T("tickets_col_price")</th>
                        <th class="text-center">@Tr.T("tickets_col_status")</th>
                        <th>@Tr.T("tickets_col_voucher")</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td class="fw-bold">@t.MatchDescription</td>
                            <td data-order="@t.MatchDate.Ticks">
                                @t.MatchDate.ToString("dd/MM/yyyy")
                                <small class="text-muted d-block">@t.MatchDate.ToString("HH:mm") UTC</small>
                            </td>
                            <td><small class="text-muted">@Tr.TranslateSector(t.SectorName)</small></td>
                            <td class="text-center">@t.SeatNumber</td>
                            <td class="text-end">€ @t.PricePaid.ToString("0.00")</td>
                            <td class="text-center">
                                @{
                                    var bc = t.Status switch { "Paid" => "success", "Cancelled" => "secondary", _ => "warning text-dark" };
                                }
                                <span class="badge bg-@bc">@t.Status</span>
                            </td>
                            <td>
                                @if (t.Status != "Cancelled")
                                {
                                    <code class="small">@t.VoucherId.ToString("D")[..8]…</code>
                                    <button class="btn btn-link btn-sm p-0 ms-1"
                                            onclick="navigator.clipboard.writeText('@t.VoucherId.ToString("D")')"
                                            title="@Tr.T("tickets_col_voucher")">
                                        📋
                                    </button>
                                }
                                else
                                {

                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    @if (t.IsCancellable && t.Status == "Paid")
                                    {
                                        <form asp-action="CancelTicket" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ticketId" value="@t.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm w-100"
                                                    onclick="return confirm('@Tr.T("tickets_cancel_confirm")')">
                                                @Tr.T("tickets_cancel_btn")
                                            </button>
                                        </form>
                                    }
                                    else if (t.Status == "Paid")
                                    {
                                        <small class="text-muted">@Tr.T("tickets_not_cancellable")</small>
                                    }
                                    @if (t.Status == "Paid")
                                    {
                                        <form asp-action="ResendVoucher" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ticketId" value="@t.Id" />
                                            <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                                                📧 @Tr.T("voucher_resend_btn")
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @* ── Season tickets ────────────────────────────────────────────────── *@
    <h2 class="fw-bold mb-3 mt-5" style="color:#001489">
        📅 @Tr.T("season_tickets_title")
    </h2>

    @if (ViewBag.SeasonTickets is IEnumerable<ChampionsLeague.Web.ViewModels.SeasonTicketHistoryVM> seasonTickets
         && seasonTickets.Any())
    {
        <div class="card border-0 shadow-sm" style="border-radius:14px;overflow:hidden">
            <table id="seasonTable" class="table table-hover table-striped align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>@Tr.T("season_col_club")</th>
                        <th>@Tr.T("tickets_col_sector")</th>
                        <th class="text-center">@Tr.T("tickets_col_seat")</th>
                        <th class="text-end">@Tr.T("tickets_col_price")</th>
                        <th>@Tr.T("season_col_purchased")</th>
                        <th class="text-center">@Tr.T("tickets_col_status")</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var st in seasonTickets)
                    {
                        <tr>
                            <td class="fw-bold">
                                @st.ClubName
                                <small class="text-muted d-block fw-normal">@st.StadiumName</small>
                            </td>
                            <td><small class="text-muted">@Tr.TranslateSector(st.SectorName)</small></td>
                            <td class="text-center">@st.SeatNumber</td>
                            <td class="text-end">€ @st.TotalPrice.ToString("0.00")</td>
                            <td data-order="@st.PurchasedAt.Ticks">
                                @st.PurchasedAt.ToString("dd/MM/yyyy")
                                <small class="text-muted d-block">@st.PurchasedAt.ToString("HH:mm") UTC</small>
                            </td>
                            <td class="text-center">
                                @{
                                    var sbc = st.IsActive ? "success" : "secondary";
                                    var sLabel = st.IsActive
                                        ? Tr.T("season_status_active")
                                        : Tr.T("season_status_cancelled");
                                }
                                <span class="badge bg-@sbc">@sLabel</span>
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-1">
                                    @if (st.IsActive)
                                    {
                                        <form asp-action="CancelSeasonTicket" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="seasonTicketId" value="@st.Id" />
                                            <button type="submit"
                                                    class="btn btn-outline-danger btn-sm w-100"
                                                    onclick="return confirm('@Tr.T("tickets_cancel_confirm")')">
                                                @Tr.T("tickets_cancel_btn")
                                            </button>
                                        </form>
                                        <form asp-action="ResendSeasonVoucher" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="seasonTicketId" value="@st.Id" />
                                            <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                                                📧 @Tr.T("voucher_resend_btn")
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <small class="text-muted">@Tr.T("tickets_not_cancellable")</small>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info d-flex align-items-center gap-3">
            <span style="font-size:2rem">📅</span>
            <div>
                @Tr.T("tickets_empty")
                <a asp-controller="SeasonTicket" asp-action="Index" class="alert-link ms-1">
                    @Tr.T("season_title")
                </a>
            </div>
        </div>
    }

@section Scripts {
    <script>
        $(function(){
            $('#ticketTable').DataTable({
                order:[[1,'desc']], pageLength:10,
                language:{ search:'', searchPlaceholder:'@Tr.T("match_col_date")...' }
            });
            $('#seasonTable').DataTable({
                order:[[4,'desc']], pageLength:10,
                language:{ search:'', searchPlaceholder:'Search...' }
            });
        });
    </script>
}