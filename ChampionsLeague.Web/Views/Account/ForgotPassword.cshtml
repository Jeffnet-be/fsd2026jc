@model ChampionsLeague.Web.ViewModels.ForgotPasswordVM
@{ ViewData["Title"] = Tr.T("forgot_title"); }

<div class="container py-4">
<div class="row justify-content-center">
<div class="col-md-5 col-lg-4">
<div class="card border-0 shadow">
    <div class="card-header text-white text-center py-3" style="background:#001489">
        <h4 class="mb-0">🔑 @Tr.T("forgot_title")</h4>
        <small style="color:#FFD700">@Tr.T("forgot_subtitle")</small>
    </div>
    <div class="card-body p-4">
        <p class="text-muted small mb-3">@Tr.T("forgot_instructions")</p>

        @* Only show error box after a failed submit *@
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Count > 0))
        {
            <div class="alert alert-danger py-2 small">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="ForgotPassword" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label class="form-label fw-semibold">@Tr.T("login_email")</label>
                <input asp-for="Email" class="form-control" placeholder="jan@example.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn w-100 fw-bold py-2"
                    style="background:#FFD700;color:#001489;border:none;border-radius:8px">
                @Tr.T("forgot_btn")
            </button>
        </form>
    </div>
    <div class="card-footer bg-white text-center py-3">
        <a asp-action="Login" class="fw-semibold">← @Tr.T("forgot_back_login")</a>
    </div>
</div>
</div>
</div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
