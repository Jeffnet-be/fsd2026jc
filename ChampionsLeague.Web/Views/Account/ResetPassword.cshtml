@model ChampionsLeague.Web.ViewModels.ResetPasswordVM
@{ ViewData["Title"] = Tr.T("reset_title"); }

<div class="container py-4">
<div class="row justify-content-center">
<div class="col-md-5 col-lg-4">
<div class="card border-0 shadow">
    <div class="card-header text-white text-center py-3" style="background:#001489">
        <h4 class="mb-0">🔐 @Tr.T("reset_title")</h4>
    </div>
    <div class="card-body p-4">
        <div asp-validation-summary="All" class="alert alert-danger py-2 small"></div>
        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />
            <div class="mb-3">
                <label class="form-label fw-semibold">@Tr.T("reg_password")</label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold">@Tr.T("reg_confirm")</label>
                <input asp-for="ConfirmPassword" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn w-100 fw-bold py-2"
                    style="background:#FFD700;color:#001489;border:none;border-radius:8px">
                @Tr.T("reset_btn")
            </button>
        </form>
    </div>
</div>
</div>
</div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
