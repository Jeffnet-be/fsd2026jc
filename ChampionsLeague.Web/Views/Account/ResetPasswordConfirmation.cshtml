@{ ViewData["Title"] = Tr.T("reset_confirmation_title"); }

<div class="container py-5 text-center">
    <div style="font-size:4rem">✅</div>
    <h2 class="fw-bold mt-3" style="color:#001489">@Tr.T("reset_confirmation_title")</h2>
    <p class="text-muted mt-2">@Tr.T("reset_confirmation_text")</p>
    <a asp-action="Login" class="btn mt-4 fw-bold text-dark"
       style="background:#FFD700;border:none;border-radius:8px;padding:10px 32px">
        @Tr.T("nav_login")
    </a>
</div>
